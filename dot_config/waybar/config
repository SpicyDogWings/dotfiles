[
  {
    "layer": "top",
    "position": "top",
    "margin": "10 10",
    "spacing": 10,
    "reload_style_on_change": true,
    "modules-left": [
      "custom/logo",
      "hyprland/workspaces"
    ],
    "modules-center": [
    ],
    "modules-right": [
      "backlight/slider",
      "hyprland/language",
      "clock"
    ],
    "custom/logo": {
      "format": "󰯉",
      "tooltip": true,
      "tooltip-format": "Menú",
      "on-click": "rofi -show drun",
      "on-click-right": "rofi -show window",
      "on-click-middle": "~/.local/bin/powerMenu.sh",
    },
    "hyprland/workspaces": {
      "on-click": "activate",
      "format": "{id} {icon}",
      "format-icons": {
        "default": "  ",
        "empty": "  ",
        "1": "",
        "2": "󰖟",
        "3": "",
        "4": "",
        "5": "󰦭",
        "6": ""
      },
      "expand": true
    },
    "hyprland/language": {
  	  "format": "   {short}",
    },
    "clock": {
      "format-alt": "    {:%a, %d %b %Y}",
      "format": "    {:%I:%M %p}",
      "tooltip-format": "<tt>{calendar}</tt>",
  	  "calendar": {
  		  "mode"          : "months",
  		  "mode-mon-col"  : 3,
  		  "weeks-pos"     : "right",
  		  "on-scroll"     : 1,
  		  "on-click-right": "mode",
  		  "format": {
  		  	"months":     "<span color='#ffead3'><b>{}</b></span>",
  		  	"days":       "<span color='#FED2E2'><b>{}</b></span>",
  		  	"weeks":      "<span color='#E9A5F1'><b>W{}</b></span>",
  		  	"weekdays":   "<span color='#C68EFD'><b>{}</b></span>",
  		  	"today":      "<span color='#8F87F1'><b><u>{}</u></b></span>"
  		  }
  	  },
  	  "actions": {
  	  	"on-click-right": "mode",
  	  	"on-scroll-up": "shift_up",
  	  	"on-scroll-down": "shift_down"
  	  }
    },
    "backlight/slider": {
      "min": 1,
      "max": 100,
      "orientation": "horizontal",
      "device": "intel_backlight",
      "expand": true
    }
  },
]
